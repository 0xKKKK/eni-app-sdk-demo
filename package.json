{
  "name": "eni-app-sdk-demo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "validate": "bun scripts/validate-demos.mjs",
    "build": "pnpm -r --filter './apps/*' build",
    "build:react": "pnpm --filter widgets-react-demo build",
    "build:vue": "pnpm --filter widgets-vue-demo build"
  },
  "pnpm": {
    "overrides": {
      "@eni-chain/app-sdk": "0.1.4",
      "@eni-chain/app-sdk-bridge": "0.1.4",
      "@eni-chain/app-sdk-core": "0.1.4",
      "@eni-chain/app-sdk-gas-exchange": "0.1.4",
      "@eni-chain/app-sdk-react": "0.1.4",
      "@eni-chain/app-sdk-swap": "0.1.4",
      "@eni-chain/app-sdk-vue": "0.1.4",
      "@eni-chain/app-sdk-wallet-adapters": "0.1.4",
      "@eni-chain/app-sdk-widgets-core": "0.1.4",
      "@eni-chain/app-sdk-widgets-react": "0.1.4",
      "@eni-chain/app-sdk-widgets-vue": "0.1.4"
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
